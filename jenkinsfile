pipeline {
    agent { label 'docker' }

    environment {
        GIT_URL            = "https://github.com/Poojithachiruve-devops/python_flask.git"
        DOCKER_HUB_REPO    = "app/pythonapp"
        IMAGE_TAG          = "v1"
        DOCKER_CREDENTIALS = "credntial_name_injenkins"
        RELEASE     = "python-app"
        NAMESPACE   = "staging"
        CHART_PATH  = "helm/python-app"
        VALUES      = "helm/values.yaml"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: "${GIT_URL}"
            }
        }
stage('install Dependencies'){
steps{
sh'''
python3 -m venv venv
pip install -r requirement.txt
'''
}
}

        stage('Docker Build & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKER_CREDENTIALS}",
                    usernameVariable: "DOCKER_USER",
                    passwordVariable: "DOCKER_PASS"
                )]) {
                    sh '''
                        echo "Logging into Docker Hub..."
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        
                        echo "Building image..."
                        docker build -t ${DOCKER_HUB_REPO}:${IMAGE_TAG} .

                        echo "Pushing image..."
                        docker push ${DOCKER_HUB_REPO}:${IMAGE_TAG}
                    '''
                }
            }
        }

        stage('Image Scan') {
            steps {
                sh '''
                    trivy image --format table \
                        --output trivy-report.txt \
                        ${DOCKER_HUB_REPO}:${IMAGE_TAG}
                '''
                archiveArtifacts 'trivy-report.txt'
            }
        }

        stage('Helm Deploy') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig)]) {
                    sh '''

                        kubectl get ns ${NAMESPACE} 
                        helm upgrade ${RELEASE} ${CHART_PATH} \
                            -n ${NAMESPACE} \
                            -f ${VALUES} \    
                    --set image.repository=${DOCKER_HUB_REPO} \
                    --set image.tag=${IMAGE_TAG}

                }
            }
        }

    }

    post {
        always {
            echo "Pipeline completed."
        }
    }
}

